NUDIBRANCH_ENV=development
NUDIBRANCH_PUBLIC_URL=http://localhost:5173
NUDIBRANCH_API_URL=http://api:8000
NUDIBRANCH_DB_PATH=/app/config/nudibranch.sqlite
NUDIBRANCH_FIRST_ADMIN_PIN=123456
NUDIBRANCH_FULL_ACCESS_API_KEY=change-me-before-exposing

JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
SLSKD_URL=http://slskd:5030
SLSKD_API_KEY=
ACOUSTID_API_KEY=

WISHLIST_SCAN_CRON=0 */6 * * *
TRASH_RETENTION_DAYS=30

# Host path bind-mounted to the in-container library (/app/library). Leave as the
# default named volume for a self-contained setup, or point it at existing music
# on disk/NAS so records keep resolving after a move (e.g. /mnt/nas-media/Music).
# The container needs read access (and write access to import new downloads).
NUDIBRANCH_LIBRARY_PATH=nudibranch-library

APNS_ENABLED=false
APNS_USE_SANDBOX=true
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=/app/config/AuthKey.p8

# Used by docker-compose.prod.yml. For a GitHub repo at
# github.com/example/nudibranch, set:
# NUDIBRANCH_IMAGE_PREFIX=ghcr.io/example/nudibranch
NUDIBRANCH_IMAGE_PREFIX=ghcr.io/YOUR_GITHUB_OWNER/YOUR_REPOSITORY
NUDIBRANCH_IMAGE_TAG=latest
